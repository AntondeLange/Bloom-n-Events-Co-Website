---
/**
 * Blog: hero, anchor nav, social widgets, CTA.
 */
import OptimizedImage from "../components/OptimizedImage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import AnchorNav from "../components/islands/AnchorNav";
import StickyMobileCTA from "../components/react/StickyMobileCTA";
import { CONTACT } from "../lib/constants";

const featuredPosts = [
  {
    date: "24 February 2026",
    category: "Corporate Events",
    title: "How We Craft Corporate Events That Feel Effortless",
    excerpt:
      "From first concept to pack-down, we coordinate design, logistics, and on-site delivery so every touchpoint feels polished and intentional.",
    href: "/events",
    image: "/assets/images/Centuria Connect140/Connect140 (2).jpg",
    imageAlt: "Guests networking at a professionally styled corporate event",
  },
  {
    date: "17 February 2026",
    category: "Workshops",
    title: "Designing School Holiday Programs Families Actually Remember",
    excerpt:
      "Our workshop activations blend creativity, flow, and practical delivery planning so centres can drive engagement across every session.",
    href: "/workshops",
    image: "/assets/images/KidsWorkshops/kidsworkshops01.jpg",
    imageAlt: "Children participating in a hands-on workshop activation",
  },
  {
    date: "10 February 2026",
    category: "Custom Displays",
    title: "From Sketch to Build: Our In-House Display Process",
    excerpt:
      "We bring concepts to life with in-house fabrication, engineering-led planning, and install teams who understand both safety and storytelling.",
    href: "/displays",
    image: "/assets/images/Centuria Breast Cancer/Centuria Breast Cancer Oct25.2.jpg",
    imageAlt: "Centuria Breast Cancer Month display installation",
  },
  {
    date: "03 February 2026",
    category: "Case Study",
    title: "Connect 140: A Corporate Activation Designed for Real Conversations",
    excerpt:
      "See how we translated strategy into a high-impact business event experience with cohesive branding, environment design, and live execution.",
    href: "/case-study-centuria-connect140",
    image: "/assets/images/Centuria Connect140/Connect140 (10).JPG",
    imageAlt: "Connect 140 corporate event experience in venue",
  },
  {
    date: "27 January 2026",
    category: "Case Study",
    title: "Neighbourhood Nibbles: Driving Community Traffic Through Experience Design",
    excerpt:
      "This campaign shows how curated activities, styling, and programming can help shopping centres increase dwell time and repeat visitation.",
    href: "/case-study-hawaiian-neighbourhood-nibbles",
    image: "/assets/images/Hawaiian Neighbourhood Nibbles/Neighbourhood-Nibbles (1).jpeg",
    imageAlt: "Neighbourhood Nibbles community activation at a shopping centre",
  },
  {
    date: "20 January 2026",
    category: "Capability",
    title: "Why Clients Choose One Team for Strategy, Design, and Delivery",
    excerpt:
      "Our integrated model reduces hand-offs and keeps quality high from brief through to final pack-down across Perth and regional WA.",
    href: "/capabilities",
    image: "/assets/images/Centuria 50th Birthday/803956c1-9edf-4c6b-a8f4-c2957cd64773.jpg",
    imageAlt: "Professionally styled event setup showing full-service delivery",
  },
];
---

<BaseLayout
  title="Blog & Social Updates | Bloom'n Events Co"
  description="Latest stories and social updates from Bloom'n Events Co. Follow our LinkedIn, Instagram, and Facebook posts for behind-the-scenes moments across Perth and Western Australia."
  path="/blog"
>
  <p class="visually-hidden">Bloom'n Events Co Blog</p>

  <!-- Blog Hero -->
  <section class="hero-section" aria-labelledby="blogHeroHeading" id="blog">
    <div class="hero-background">
      <OptimizedImage
        src="/assets/images/Centuria 50th Birthday/60a182ec-9f16-4f20-919b-59e9451bb4a8.jpg"
        alt="Bloom'n Events Co blog and social updates"
        class="hero-image"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        sizes="100vw"
        width="1600"
        height="900"
      />
    </div>
    <div class="hero-overlay" aria-hidden="true" />
    <div class="hero-content">
      <div class="w-full max-w-4xl px-4 text-center md:px-6">
        <h1 id="blogHeroHeading" class="hero-headline">
          Blog & Social Updates
        </h1>
        <p class="hero-subhead">
          Stories, highlights, and behind-the-scenes moments from Bloom'n Events Co. Follow along for the latest
          projects, community activations, and creative builds across Western Australia.
        </p>
        <div class="hero-cta">
          <a href="/contact" class="btn-gold">Start the Conversation</a>
          <a href="/gallery" class="btn-outline-gold">View Our Work</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Anchor nav -->
  <AnchorNav
    links={[
      { href: "#blog", label: "Blog" },
      { href: "#featured-posts", label: "Featured Posts" },
      { href: "#linkedin", label: "LinkedIn" },
      { href: "#instagram", label: "Instagram" },
      { href: "#facebook", label: "Facebook" },
    ]}
    client:idle
  />

  <!-- Featured Posts -->
  <section class="section-secondary" aria-labelledby="featuredPostsHeading" id="featured-posts">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <h2 id="featuredPostsHeading" class="heading-blush-bg text-center mb-5">
        Featured Articles
        <span class="featured-heading-subtext">
          Helpful reads on the work Bloom'n Events Co does best, from full-service event delivery to high-impact activations.
        </span>
      </h2>
      <div class="grid gap-6 md:grid-cols-2">
        {featuredPosts.map((post) => (
          <article class="blog-post-card card shadow h-full">
            <a href={post.href} class="blog-post-image-link" aria-label={`Read article: ${post.title}`}>
              <OptimizedImage
                src={post.image}
                alt={post.imageAlt}
                class="blog-post-image"
                loading="lazy"
                decoding="async"
                width={1200}
                height={750}
                sizes="(max-width: 767px) 92vw, 45vw"
              />
            </a>
            <div class="card-body p-4 md:p-5">
              <div class="blog-post-meta">
                <span class="blog-post-pill">{post.date}</span>
                <span class="blog-post-pill">{post.category}</span>
              </div>
              <h3 class="blog-post-title">
                <a href={post.href} class="text-gold hover:underline">{post.title}</a>
              </h3>
              <p class="text-charcoal mb-0">{post.excerpt}</p>
              <a href={post.href} class="blog-post-link text-gold hover:underline">Read article -&gt;</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- LinkedIn -->
  <section class="section-main" aria-labelledby="linkedinHeading" id="linkedin">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <h2 id="linkedinHeading" class="heading-blush-bg text-center">LinkedIn</h2>
        <div class="card shadow">
          <div class="card-body p-4 md:p-5">
            <div class="sk-ww-linkedin-page-post" data-embed-id="25651346"></div>
            <script src="https://widgets.sociablekit.com/linkedin-page-posts/widget.js" defer is:inline></script>
            <p class="mt-3 mb-0 text-center text-charcoal">
              If this feed does not load, visit
              {" "}
              <a
                href="https://www.linkedin.com/company/bloom-n-events-co/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gold hover:underline"
              >
                Bloom'n Events Co on LinkedIn
              </a>
              .
            </p>
          </div>
        </div>
      </div>
  </section>

  <!-- Instagram -->
  <section class="section-main" aria-labelledby="instagramHeading" id="instagram">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <h2 id="instagramHeading" class="heading-blush-bg text-center">Instagram</h2>
        <div class="card shadow">
          <div class="card-body p-4 md:p-5">
            <div class="sk-instagram-feed" data-embed-id="25613579"></div>
            <script src="https://widgets.sociablekit.com/instagram-feed/widget.js" defer is:inline></script>
            <p class="mt-3 mb-0 text-center text-charcoal">
              If this feed does not load, visit
              {" "}
              <a
                href="https://www.instagram.com/bloomneventsco/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gold hover:underline"
              >
                @bloomneventsco on Instagram
              </a>
              .
            </p>
          </div>
        </div>
      </div>
  </section>

  <!-- Facebook -->
  <section class="section-main" aria-labelledby="facebookHeading" id="facebook">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <h2 id="facebookHeading" class="heading-blush-bg text-center">Facebook</h2>
        <div class="card shadow">
          <div class="card-body p-4 md:p-5">
            <div class="sk-ww-facebook-profile" data-embed-id="25651352"></div>
            <script src="https://widgets.sociablekit.com/facebook-profile/widget.js" defer is:inline></script>
            <p class="mt-3 mb-0 text-center text-charcoal">
              If this feed does not load, visit
              {" "}
              <a
                href="https://www.facebook.com/bloomneventsco/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gold hover:underline"
              >
                Bloom'n Events Co on Facebook
              </a>
              .
            </p>
          </div>
        </div>
      </div>
  </section>

  <!-- Final CTA -->
  <section class="section-main" aria-labelledby="cta-heading" id="cta">
    <div class="mx-auto max-w-4xl px-4 md:px-6">
      <h2 id="cta-heading" class="heading-blush-bg text-center">Let's create your next experience.</h2>
      <div class="card shadow cta-card">
        <div class="card-body p-5 text-center">
          <p class="lead text-charcoal mb-5">
            We invite you to create with us. One team, one accountable partner, and a shared commitment to craft.
          </p>
          <div class="cta-buttons mb-4">
            <a href="/contact" class="btn-gold btn-lg me-3 mb-3">Start the Conversation</a>
            <a href="/about" class="btn-outline-gold btn-lg mb-3">Learn More About Us</a>
          </div>
          <p class="text-charcoal mt-4 mb-0">
            <i class="bi bi-telephone-fill" aria-hidden="true"></i>{" "}
            <a href={`tel:${CONTACT.phone.replace(/\s/g, "")}`} class="text-gold hover:underline">
              {CONTACT.phone}
            </a>{" "}
            | <i class="bi bi-envelope-fill" aria-hidden="true"></i>{" "}
            <a href={`mailto:${CONTACT.email}`} class="text-gold hover:underline">
              {CONTACT.email}
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const applySocialA11yFixes = () => {
        document.querySelectorAll("button.sk-post-share").forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          if (!button.getAttribute("aria-label")) {
            const author =
              button
                .closest(".sk-post-item")
                ?.querySelector(".sk-post-username")
                ?.textContent?.trim() || "";
            button.setAttribute("aria-label", author ? `Share post from ${author}` : "Share this post");
          }
        });

        document.querySelectorAll("button.sk-slider__btn").forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          if (button.getAttribute("aria-label")) return;
          const isPrevious = button.classList.contains("sk-slider__btn--left");
          button.setAttribute("aria-label", isPrevious ? "Previous posts" : "Next posts");
        });

        document.querySelectorAll("a.sk-header-name, a.sk-post-username").forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) return;
          const visibleText = link.textContent?.trim();
          if (!visibleText) return;
          if (link.getAttribute("aria-label") !== visibleText) {
            link.setAttribute("aria-label", visibleText);
          }
        });
      };

      const observer = new MutationObserver(() => applySocialA11yFixes());
      observer.observe(document.body, { childList: true, subtree: true });
      applySocialA11yFixes();

      window.addEventListener(
        "beforeunload",
        () => {
          observer.disconnect();
        },
        { once: true }
      );
    })();
  </script>

  <style>
    .blog-post-card {
      background-color: var(--color-champers);
      border: 2px solid var(--color-gold);
      border-radius: 0.75rem;
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .blog-post-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
    }

    .blog-post-image-link {
      display: block;
      border-bottom: 1px solid rgba(191, 155, 48, 0.35);
    }

    :global(.blog-post-image-link picture) {
      display: block;
      width: 100%;
    }

    :global(.blog-post-image-link img.blog-post-image) {
      width: 100%;
      height: clamp(14rem, 24vw, 18rem);
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .blog-post-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .blog-post-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid rgba(191, 155, 48, 0.65);
      background: rgba(191, 155, 48, 0.16);
      color: var(--color-charcoal);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
    }

    .blog-post-title {
      margin-bottom: 0.75rem;
      line-height: 1.3;
      font-size: 1.3rem;
    }

    .blog-post-link {
      display: inline-flex;
      margin-top: 1rem;
      font-weight: 700;
    }

    .featured-heading-subtext {
      display: block;
      margin-top: 0.85rem;
      font-size: 1rem;
      font-weight: 500;
      line-height: 1.55;
      letter-spacing: normal;
      text-transform: none;
      color: var(--color-charcoal);
    }

    :global(.sk-ww-linkedin-page-post .sk-header-name),
    :global(.sk-ww-linkedin-page-post .sk-post-username),
    :global(.sk-instagram-feed .instagram-user-root-container .bio-website) {
      color: var(--color-charcoal) !important;
    }
  </style>

  <StickyMobileCTA client:idle />
</BaseLayout>
